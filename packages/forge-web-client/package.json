{
  "name": "@handharr-labs/forge-web-client",
  "version": "0.6.1",
  "description": "Frontend primitives for Handharr Labs Next.js apps — ApiClient, CacheClient, FileUtils",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": [
      "./src/*.ts",
      "./src/*.tsx"
    ]
  },
  "files": [
    "src",
    "!src/**/*.test.ts"
  ],
  "dependencies": {
    "@handharr-labs/forge-core": "*"
  },
  "peerDependencies": {
    "@supabase/ssr": ">=0.5",
    "@tanstack/react-query": ">=5",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@supabase/ssr": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/handharr-labs/web-forge-kit.git",
    "directory": "packages/forge-web-client"
  },
  "devDependencies": {
    "@supabase/ssr": "0.9.0",
    "@tanstack/react-query": "^5.101.0"
  },
  "scripts": {
    "type-check": "tsc --noEmit"
  }
}
