{
  "name": "@handharr-labs/web-server",
  "version": "0.4.1",
  "description": "Backend primitives for Handharr Labs Next.js apps — DB adapters, server action utilities",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": [
      "./src/*.ts",
      "./src/*.tsx"
    ]
  },
