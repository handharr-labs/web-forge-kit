    "@supabase/supabase-js": ">=2"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    },
    "postgres": {
      "optional": true
    },
    "@supabase/ssr": {
      "optional": true
    },
    "@supabase/supabase-js": {
      "optional": true
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/handharr-labs/web-forge-kit.git",
    "directory": "packages/web-server"
  },
  "devDependencies": {
    "@supabase/ssr": "0.9.0",
    "@supabase/supabase-js": "2.98.0",
    "@types/node": "25.9.3",
    "drizzle-orm": "0.45.1",
    "postgres": "3.4.8"
  },
  "scripts": {
    "type-check": "tsc --noEmit"
  }
}
