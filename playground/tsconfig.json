{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@handharr-labs/forge-core": ["../packages/forge-core/src/index.ts"],
      "@handharr-labs/forge-core/*": ["../packages/forge-core/src/*"],
      "@handharr-labs/forge-ui-base-bronze": ["../packages/forge-ui-base-bronze/src/index.ts"],
      "@handharr-labs/forge-ui-base-bronze/*": ["../packages/forge-ui-base-bronze/src/*"],
      "@handharr-labs/forge-ui-base-silver": ["../packages/forge-ui-base-silver/src/index.ts"],
      "@handharr-labs/forge-ui-base-silver/*": ["../packages/forge-ui-base-silver/src/*"],
      "@handharr-labs/forge-ui-base-gold": ["../packages/forge-ui-base-gold/src/index.ts"],
      "@handharr-labs/forge-ui-base-gold/*": ["../packages/forge-ui-base-gold/src/*"],
      "@handharr-labs/ui-cikal-showcase": ["../packages/ui-cikal-showcase/src/index.ts"],
      "@handharr-labs/ui-cikal-showcase/*": ["../packages/ui-cikal-showcase/src/*"],
      "@handharr-labs/forge-ui-uno": ["../packages/forge-ui-uno/src/index.ts"],
      "@handharr-labs/forge-ui-uno/*": ["../packages/forge-ui-uno/src/*"],
      "@handharr-labs/forge-web-client": ["../packages/forge-web-client/src/index.ts"],
      "@handharr-labs/forge-web-client/*": ["../packages/forge-web-client/src/*"],
      "@handharr-labs/forge-auth/server": ["../packages/forge-auth/src/server/index.ts"],
      "@handharr-labs/forge-auth/client": ["../packages/forge-auth/src/client/index.tsx"],
      "@handharr-labs/forge-auth/middleware": ["../packages/forge-auth/src/middleware/index.ts"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
